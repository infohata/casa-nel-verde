<div class="lightbox-modal" data-lightbox-modal hidden>
    <div class="lightbox-backdrop" data-lightbox-close></div>
    <div class="lightbox-shell" role="dialog" aria-modal="true" aria-label="Image preview">
        <button class="lightbox-close" type="button" aria-label="Close image preview" data-lightbox-close>
            Close
        </button>
        <div class="lightbox-stage" data-lightbox-stage>
            <div class="lightbox-spinner" data-lightbox-spinner aria-hidden="true"></div>
            <img class="lightbox-image" data-lightbox-image alt="" />
        </div>
        <p class="lightbox-caption" data-lightbox-caption></p>
    </div>
</div>

<script>
    import Panzoom from "@panzoom/panzoom";

    const modal = document.querySelector("[data-lightbox-modal]");
    const stage = modal?.querySelector("[data-lightbox-stage]");
    const spinner = modal?.querySelector("[data-lightbox-spinner]");
    const image = modal?.querySelector("[data-lightbox-image]");
    const caption = modal?.querySelector("[data-lightbox-caption]");
    const closeButtons = modal?.querySelectorAll("[data-lightbox-close]");

    let panzoomInstance = null;
    let lastFocusedElement = null;

    function ensurePanzoom() {
        if (!image || !stage || panzoomInstance) {
            return;
        }

        panzoomInstance = Panzoom(image, {
            maxScale: 5,
            minScale: 1,
            contain: "outside",
            step: 0.2,
        });

        stage.addEventListener("wheel", (event) => {
            event.preventDefault();
            panzoomInstance.zoomWithWheel(event);
        });
    }

    function centerImageAtCurrentScale() {
        if (!image || !stage || !panzoomInstance || !image.naturalWidth || !image.naturalHeight) {
            return;
        }

        const stageWidth = stage.clientWidth;
        const stageHeight = stage.clientHeight;
        if (!stageWidth || !stageHeight) {
            return;
        }

        const currentScale = panzoomInstance.getScale();
        const renderedWidth = image.naturalWidth * currentScale;
        const renderedHeight = image.naturalHeight * currentScale;
        const centerX = (stageWidth - renderedWidth) / 2;
        const centerY = (stageHeight - renderedHeight) / 2;
        panzoomInstance.pan(centerX, centerY, { animate: false, force: true });
    }

    function openLightbox(source, altText) {
        if (!modal || !image || !caption || !stage) {
            return;
        }

        ensurePanzoom();
        lastFocusedElement = document.activeElement;
        stage.classList.add("is-loading");
        spinner?.classList.add("is-visible");

        image.onload = () => {
            stage.classList.remove("is-loading");
            spinner?.classList.remove("is-visible");
            panzoomInstance?.reset({ animate: false });
            requestAnimationFrame(centerImageAtCurrentScale);
        };

        image.onerror = () => {
            stage.classList.remove("is-loading");
            spinner?.classList.remove("is-visible");
        };

        image.src = source;
        image.alt = altText || "Image preview";
        caption.textContent = altText || "";
        modal.hidden = false;
        modal.classList.add("is-open");
        document.body.classList.add("lightbox-open");

        requestAnimationFrame(() => {
            panzoomInstance?.reset({ animate: false });
            requestAnimationFrame(centerImageAtCurrentScale);
        });

        if (image.complete && image.naturalWidth > 0) {
            image.onload?.(new Event("load"));
        }
    }

    function closeLightbox() {
        if (!modal) {
            return;
        }

        modal.classList.remove("is-open");
        modal.hidden = true;
        document.body.classList.remove("lightbox-open");
        stage?.classList.remove("is-loading");
        spinner?.classList.remove("is-visible");
        panzoomInstance?.reset({ animate: false });
        if (lastFocusedElement instanceof HTMLElement) {
            lastFocusedElement.focus();
        }
    }

    document.addEventListener("click", (event) => {
        const trigger = event.target.closest("[data-lightbox-src]");
        if (!trigger) {
            return;
        }

        event.preventDefault();
        const source = trigger.getAttribute("data-lightbox-src");
        const altText = trigger.getAttribute("data-lightbox-alt");
        if (!source) {
            return;
        }

        openLightbox(source, altText);
    });

    closeButtons?.forEach((button) => {
        button.addEventListener("click", closeLightbox);
    });

    document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && modal?.classList.contains("is-open")) {
            closeLightbox();
        }
    });

    window.addEventListener("resize", () => {
        if (modal?.classList.contains("is-open")) {
            requestAnimationFrame(centerImageAtCurrentScale);
        }
    });
</script>
