---
interface Props {
    whatsappUrl: string;
    telegramUrl: string;
}

const { whatsappUrl, telegramUrl } = Astro.props;
---

<aside class="floating-chat" aria-label="Quick chat actions">
    <a
        class="floating-chat-icon floating-chat-whatsapp"
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="Open WhatsApp chat"
    >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
                d="M12 2a10 10 0 0 0-8.7 14.95L2 22l5.2-1.3A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.08.76.82-3-.2-.31A8.2 8.2 0 1 1 12 20.2Zm4.5-6.14c-.25-.12-1.48-.73-1.7-.82-.23-.08-.39-.12-.56.12-.16.25-.64.82-.78.99-.14.16-.29.18-.54.06-.25-.12-1.05-.39-2-1.24-.74-.66-1.23-1.47-1.38-1.71-.15-.25-.02-.38.11-.5.11-.11.25-.28.37-.42.12-.14.16-.24.25-.4.08-.17.04-.3-.02-.42-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43l-.48-.01c-.16 0-.42.06-.64.3-.22.25-.84.82-.84 2 0 1.18.86 2.32.98 2.48.12.16 1.68 2.56 4.07 3.59.57.24 1.01.38 1.36.48.57.18 1.09.15 1.5.09.46-.07 1.48-.6 1.69-1.17.21-.56.21-1.05.15-1.16-.06-.1-.22-.16-.47-.28Z"
            ></path>
        </svg>
        <span class="sr-only">WhatsApp</span>
    </a>

    <a
        class="floating-chat-icon floating-chat-telegram"
        href={telegramUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="Open Telegram chat"
    >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
                d="M21.5 4.4c.3-.95-.34-1.84-1.28-1.53L3.66 8.47c-.98.33-.97 1.71 0 2.02l4.2 1.33 1.62 5.2c.28.91 1.4 1.2 2.08.54l2.35-2.28 3.9 2.86c.72.53 1.74.15 1.94-.74L21.5 4.4ZM9.2 11.52l8.78-5.54-6.97 7.18a.7.7 0 0 0-.18.34l-.66 2.78-.97-3.1a.7.7 0 0 0-.45-.45L5.9 11.8l3.3-.28Z"
            ></path>
        </svg>
        <span class="sr-only">Telegram</span>
    </a>
</aside>
