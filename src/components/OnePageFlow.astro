---
import BacklinkPlatformsSection from "./BacklinkPlatformsSection.astro";
import CtaBand from "./CtaBand.astro";
import AmenitiesSection from "./AmenitiesSection.astro";
import CookieNotice from "./CookieNotice.astro";
import FloatingChatButtons from "./FloatingChatButtons.astro";
import HeroSection from "./HeroSection.astro";
import HighlightsCardsSection from "./HighlightsCardsSection.astro";
import ImageLightbox from "./ImageLightbox.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import Layout from "./Layout.astro";
import LocationShowcaseSection from "./LocationShowcaseSection.astro";
import { get_locale_content, media_map, site_config_data } from "../lib/content";
import { build_alternates, type SupportedLanguage } from "../lib/i18n";

interface Props {
    lang: SupportedLanguage;
}

const { lang } = Astro.props;
const locale = get_locale_content(lang);
const chat_links = site_config_data.chatLinks;

function build_tracking_link(baseUrl: string, sourceSection: string): string {
    try {
        const tracked = new URL(baseUrl);
        tracked.searchParams.set("utm_source", "website");
        tracked.searchParams.set("utm_medium", "cta");
        tracked.searchParams.set("utm_campaign", "one_page");
        tracked.searchParams.set("utm_content", `${lang}_${sourceSection}`);
        return tracked.toString();
    } catch {
        return baseUrl;
    }
}

const highlight_cards = locale.highlights.cards
    .map((card) => {
        const media = media_map[card.imageId];
        if (!media) {
            return null;
        }

        return {
            title: card.title,
            description: card.description,
            imageSrc: media.src,
            imageAlt: media.alt[lang] ?? media.alt.it,
            imagePosition: card.imageId === "highlight-local-experience" ? "center bottom" : undefined,
        };
    })
    .filter(
        (
            card,
        ): card is {
            title: string;
            description: string;
            imageSrc: string;
            imageAlt: string;
        } => card !== null,
    );

const location_cards = locale.location.imageIds
    .map((image_id) => {
        const media = media_map[image_id];
        if (!media) {
            return null;
        }

        return {
            imageSrc: media.src,
            imageAlt: media.alt[lang] ?? media.alt.it,
        };
    })
    .filter((card): card is { imageSrc: string; imageAlt: string } => card !== null);

const amenities_cards = locale.amenities.cards
    .map((card) => {
        if (!card.imageId) {
            return {
                title: card.title,
                description: card.description,
            };
        }

        const media = media_map[card.imageId];
        if (!media) {
            return {
                title: card.title,
                description: card.description,
            };
        }

        return {
            title: card.title,
            description: card.description,
            imageSrc: media.src,
            imageAlt: media.alt[lang] ?? media.alt.it,
        };
    })
    .filter((card) => card.title && card.description);

---

<Layout
    lang={lang}
    title={locale.seo.title}
    description={locale.seo.description}
    canonicalPath={`/${lang}/`}
    alternates={build_alternates("/")}
>
    <header class="top-nav">
        <div class="container top-nav-inner">
            <a class="brand" href={`/${lang}/`}>{site_config_data.siteName}</a>
            <LanguageSwitcher currentLanguage={lang} />
        </div>
    </header>

    <main id="main-content">
        <HeroSection
            eyebrow={locale.hero.eyebrow}
            title={locale.hero.title}
            description={locale.hero.description}
            backgroundImageSrc={media_map["hero-sea"].src}
            backgroundImageAlt={media_map["hero-sea"].alt[lang]}
            aerialImageSrc={media_map["hero-aerial"].src}
            aerialImageAlt={media_map["hero-aerial"].alt[lang]}
            whatsappUrl={build_tracking_link(chat_links.whatsapp, "hero_whatsapp")}
            telegramUrl={build_tracking_link(chat_links.telegram, "hero_telegram")}
            whatsappLabel={locale.hero.primaryCtaLabel}
            telegramLabel={locale.hero.secondaryCtaLabel}
        />

        <HighlightsCardsSection
            title={locale.highlights.title}
            lead={locale.highlights.lead}
            cards={highlight_cards}
        />

        <LocationShowcaseSection
            title={locale.location.title}
            placeName={locale.location.placeName}
            description={locale.location.description}
            backgroundImageSrc={media_map["location-background"].src}
            backgroundImageAlt={media_map["location-background"].alt[lang]}
            cards={location_cards}
        />

        <AmenitiesSection
            title={locale.amenities.title}
            lead={locale.amenities.lead}
            cards={amenities_cards}
        />

        <BacklinkPlatformsSection
            title={locale.backlinkPlatforms.title}
            lead={locale.backlinkPlatforms.lead}
            platforms={site_config_data.bookingPlatforms}
        />

        <CtaBand
            title={locale.finalCta.title}
            description={locale.finalCta.description}
            backgroundImageSrc={media_map["final-cta-background"].src}
            backgroundImageAlt={media_map["final-cta-background"].alt[lang]}
            whatsappUrl={build_tracking_link(chat_links.whatsapp, "final_whatsapp")}
            telegramUrl={build_tracking_link(chat_links.telegram, "final_telegram")}
            whatsappLabel={locale.finalCta.primaryCtaLabel}
            telegramLabel={locale.finalCta.secondaryCtaLabel}
        />
    </main>

    <CookieNotice lang={lang} />
    <FloatingChatButtons
        whatsappUrl={build_tracking_link(chat_links.whatsapp, "floating_whatsapp")}
        telegramUrl={build_tracking_link(chat_links.telegram, "floating_telegram")}
    />
    <ImageLightbox />
</Layout>
