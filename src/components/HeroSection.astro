---
interface Props {
    eyebrow: string;
    title: string;
    description: string;
    imageSrc: string;
    imageAlt: string;
    whatsappUrl: string;
    telegramUrl: string;
    whatsappLabel: string;
    telegramLabel: string;
}

const {
    eyebrow,
    title,
    description,
    imageSrc,
    imageAlt,
    whatsappUrl,
    telegramUrl,
    whatsappLabel,
    telegramLabel,
} = Astro.props;
---

<section class="section hero">
    <div class="container hero-grid">
        <div>
            <p class="hero-eyebrow">{eyebrow}</p>
            <h1 class="section-title">{title}</h1>
            <p class="section-lead">{description}</p>
            <div class="hero-actions">
                <a class="button button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
                    {whatsappLabel}
                </a>
                <a class="button button-secondary" href={telegramUrl} target="_blank" rel="noreferrer">
                    {telegramLabel}
                </a>
            </div>
        </div>
        <div class="hero-image card">
            <img src={imageSrc} alt={imageAlt} loading="eager" />
        </div>
    </div>
</section>
